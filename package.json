{
    "name": "multi-terminal",
    "version": "1.0.0",
    "description": "A premium multi-terminal Windows application for vibe coding",
    "main": "src/main/main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "dist": "electron-builder --win",
        "postinstall": "electron-builder install-app-deps"
    },
    "keywords": [
        "terminal",
        "multi-terminal",
        "electron",
        "vibe-coding"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@electron/rebuild": "^4.0.3",
        "electron": "^33.0.0",
        "electron-builder": "^25.1.8",
        "png-to-ico": "^3.0.1"
    },
    "dependencies": {
        "@xterm/addon-fit": "^0.10.0",
        "@xterm/addon-web-links": "^0.11.0",
        "@xterm/addon-webgl": "^0.18.0",
        "@xterm/xterm": "^5.5.0",
        "node-pty": "^1.0.0"
    },
    "build": {
        "appId": "com.multiterminal.app",
        "productName": "Multi Terminal",
        "win": {
            "requestedExecutionLevel": "requireAdministrator",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.png"
        },
        "nsis": {
            "oneClick": true,
            "perMachine": false,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Multi Terminal"
        },
        "files": [
            "src/main/**/*",
            "src/renderer/**/*",
            "assets/**/*",
            "scripts/**/*",
            "node_modules/@xterm/**/*",
            "node_modules/node-pty/**/*"
        ],
        "extraResources": []
    }
}
